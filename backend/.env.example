# ============================================
# Fission Protocol Backend — Environment
# ============================================

# Solana
PROTOCOL_KEYPAIR=your_base58_private_key_here
PROTOCOL_PUBKEY=your_public_key_here
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Firebase (JSON string of service account credentials)
FIREBASE_SERVICE_ACCOUNT=

# Server
PORT=3001
NODE_ENV=development

# Drift
DRIFT_ENV=mainnet-beta

# Jupiter
JUPITER_API_URL=https://api.jup.ag/swap/v1

# Worker intervals (seconds)
MIN_INTERVAL_SECONDS=1800
MAX_INTERVAL_SECONDS=7200
