# ============================================
# Fission Protocol Backend — Environment
# ============================================

# ── Solana ──────────────────────────────────
# Base58-encoded secret key for signing transactions
PROTOCOL_KEYPAIR=your_base58_private_key_here
# Public key (derived from keypair, or standalone for read-only mode)
PROTOCOL_PUBKEY=HgeoK9ASUYey5g2MBSGHfCdauDzLv93x6vAs7j492i9c
# RPC endpoint — use a paid provider for production (Helius, QuickNode, Triton)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ── Firebase ────────────────────────────────
# JSON string of service account credentials, or path to JSON file
# Omit for mock mode (in-memory store, data lost on restart)
FIREBASE_SERVICE_ACCOUNT=

# ── Server ──────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Jupiter ─────────────────────────────────
# Swap API (for buybacks)
JUPITER_API_URL=https://api.jup.ag/swap/v1
# Perpetuals program (mainnet)
JUPITER_PERPS_PROGRAM_ID=PERPHjGBqRHArX4DySjwM6UJHiR3sWAatqfdBS2qQJu
# JLP Pool address (mainnet)
JLP_POOL_ADDRESS=5BUwFW4nRbftYTDMbgxykoFWKIYhqoLFgsN8KfaX9jMH

# ── Worker Intervals (seconds) ──────────────
MIN_INTERVAL_SECONDS=1800
MAX_INTERVAL_SECONDS=7200

# ── Risk Management ────────────────────────
# All values are decimals (0.30 = 30%)
# Take profit when PnL exceeds this % of deployed capital
TAKE_PROFIT_PCT=0.30
# Reduce position by this % when taking profit
TAKE_PROFIT_REDUCE_PCT=0.25
# Auto-reduce when drawdown exceeds this %
MAX_DRAWDOWN_PCT=0.40
# Reduce by this % on drawdown trigger
DRAWDOWN_REDUCE_PCT=0.50
# Auto-close if underlying drops this % from entry
CIRCUIT_BREAKER_PCT=0.50
# Keep this % of position fund as cash buffer
RESERVE_PCT=0.20
# Minimum SOL to deploy in a single position add
MIN_DEPLOY_SOL=0.01
# Maximum SOL per position
MAX_POSITION_SOL=100
# Liquidation proximity warning threshold (margin ratio)
LIQUIDATION_WARNING_PCT=0.15
